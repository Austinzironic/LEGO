          "locale": {
            "fi-fi": {
              "display_title": "BLACK PHANTOM",
              "description": "”Hälytys! BLACK PHANTOM on nähty Hero Factoryssä! Se on pysäytettävä hinnalla millä hyvänsä, mutta ole varovainen. Se on aseistettu ilkeällä Arachinx-robotilla, sapelilaukaisimella ja nuijasapelisauvalla, ja se käyttää niitä ta itavasti! Luotamme sinuun!”",
              "title": "BLACK PHANTOM",
              "tags": []
            },
            "en-us": {
              "bullet_points": "•  Features arachnix drone with ball shooter, sabre strikers, staff with razor sabre and mace\r\n•  Highly flexible and poseable elements\r\n•  Includes unique code worth 500 game points for LEGO® Hero Factory BREAKOUT game\r\n•  Battle with hero 6202 ROCKA!\r\n•  Combine with 6202 ROCKA for a even bigger model!\r\n•  Stands over 11” (30cm) tall!",
              "display_title": "BLACK PHANTOM",
              "description": "“Red alert! BLACK PHANTOM has been spotted inside the Hero Factory! He must be stopped at all costs, but be warned. He’s armed with an evil Arachnix drone, sabre strikers, staff with razor sabre and mace. Watch out! He knows just how to use them! We know you won’t fail us!”",
